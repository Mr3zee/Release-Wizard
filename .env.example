# Release Wizard — Local Development Environment
# Copy to .env and generate secrets: ./scripts/setup-local-env.sh
# Never commit, share, or copy the generated .env file.

# --- Database (defaults match docker-compose.yml) ---
DB_URL=jdbc:postgresql://localhost:5432/release_wizard
DB_USER=postgres
DB_PASSWORD=postgres
DB_MAX_POOL_SIZE=10

# --- Server ---
PORT=8080
HOST=0.0.0.0
APP_VERSION=dev

# --- Auth — REQUIRED (generate with: openssl rand -hex 32) ---
AUTH_SESSION_SIGN_KEY=CHANGE_ME
# Optional encryption key (generate with: openssl rand -hex 16 for AES-128, or -hex 32 for AES-256)
AUTH_SESSION_ENCRYPT_KEY=

# --- Encryption — REQUIRED (generate with: openssl rand -base64 32) ---
ENCRYPTION_KEY=CHANGE_ME

# --- Webhooks ---
WEBHOOK_BASE_URL=http://localhost:8080

# --- CORS (for split-mode dev with frontend on separate port) ---
CORS_ALLOWED_ORIGIN_1=http://localhost:8081

# --- Session security (disable for local dev over HTTP) ---
SECURE_COOKIE=false

# --- Session lifetimes (defaults are fine for dev) ---
# BROWSER_SESSION_TTL_SECONDS=2592000
# DESKTOP_SESSION_TTL_SECONDS=31536000
# SESSION_REFRESH_THRESHOLD_SECONDS=60
# BROWSER_ABSOLUTE_LIFETIME_SECONDS=7776000
# DESKTOP_ABSOLUTE_LIFETIME_SECONDS=63072000

# --- Password policy ---
# PASSWORD_MIN_LENGTH=12
# PASSWORD_REQUIRE_UPPERCASE=true
# PASSWORD_REQUIRE_DIGIT=true
# PASSWORD_REQUIRE_SPECIAL=false

# --- Google OAuth (optional — leave blank to disable) ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8080/api/v1/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
